{
  "name": "modulo2",
  "version": "1.0.0",
  "description": "DOE, Jest coverage y ESLint",
  "scripts": {
    "test:coverage": "jest --coverage",
    "test:baja-cobertura": "jest parte2-cobertura/binarySearch.baja-cobertura.test.js --coverage",
    "lint": "eslint parte2-eslint/binarySearchBad.js --config parte2-eslint/.eslintrc.json"
